# Copy this file to `.env` and fill in your values. `.env` is gitignored;
# this `.env.example` is committed as documentation of what the scripts read.
#
# WHO READS THIS FILE: the data-generation + eval scripts (data/gen_concepts.py,
# data/generate.py, eval/base_vs_tuned.py, litmus/*) load it via litmus.env.load_env().
# TRAINING DOES NOT READ THIS FILE — Colab QLoRA (train/train_qlora.ipynb) needs no
# secrets here (Qwen3-4B is an open, ungated model). See the note at the bottom.


OPENAI_API_KEY=sk-...


# OPENAI_BASE_URL=https://<your-gateway-host>/api/inference/openai/v1

# --- Training (Colab) --------------------------------------------------------
# Not needed here. Qwen3-4B downloads without auth. You would only ever set an
# HF token (in the Colab runtime, NOT this file) if you later push the trained
# adapter to the Hugging Face Hub:  HF_TOKEN=hf_...
